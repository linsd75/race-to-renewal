{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    { "route": "/login", "rewrite": "/.auth/login/aad" },
    { "route": "/logout", "rewrite": "/.auth/logout" },
    { "route": "/*", "allowedRoles": ["msft"] }
  ],
  "responseOverrides": {
    "401": { "statusCode": 302, "redirect": "/.auth/login/aad" },
    "403": { "statusCode": 302, "redirect": "/.auth/login/aad" }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*", "/*.{css,js,png,jpg,svg,ico}"]
  },
  "auth": {
    "rolesSource": "/api/GetRoles"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Content-Security-Policy": "frame-ancestors 'self' https://teams.microsoft.com https://*.teams.microsoft.com https://*.skype.com https://*.office.com https://*.microsoft365.com"
  }
}
